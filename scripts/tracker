#!/usr/bin/env bash
# tracker — Unified CLI for Agent Tracker
# Usage: tracker <command> [options]

set -euo pipefail

source "$(dirname "$0")/env.sh"

LOG_FILE="$TRACKER_LOG_DIR/tracker-server.log"
LAUNCHD_LABEL="dev.heygo.tracker-server"
TOKEN="$TRACKER_TOKEN"

# Authenticated curl helper
acurl() {
    local method="${1:-GET}"
    local path="$2"
    shift 2
    curl -s -m 10 -X "$method" "$TRACKER_URL$path" \
        -H "Authorization: Bearer $TOKEN" \
        -H "Content-Type: application/json" \
        "$@"
}

# Color helpers
green() { printf '\033[32m%s\033[0m' "$*"; }
yellow() { printf '\033[33m%s\033[0m' "$*"; }
red() { printf '\033[31m%s\033[0m' "$*"; }
dim() { printf '\033[2m%s\033[0m' "$*"; }
bold() { printf '\033[1m%s\033[0m' "$*"; }

case "${1:-help}" in
    status)
        echo "=== Agent Tracker Status ==="
        # Check if server is running
        if curl -s -m 2 "$TRACKER_URL/health" >/dev/null 2>&1; then
            pid=$(curl -s -m 2 "$TRACKER_URL/health" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','unknown'))" 2>/dev/null || echo "unknown")
            echo "  Server:  $(green "running") on ${TRACKER_URL}"
            # Get uptime from health check
            health=$(acurl GET /api/health 2>/dev/null || echo "{}")
            echo "  Health:  $health"
        else
            echo "  Server:  $(red "not running")"
        fi
        # launchd status
        if launchctl list "$LAUNCHD_LABEL" &>/dev/null 2>&1; then
            lpid=$(launchctl list "$LAUNCHD_LABEL" 2>/dev/null | awk 'NR==2 {print $1}')
            echo "  Launchd: $(green "loaded") (PID: ${lpid:-?})"
        else
            echo "  Launchd: $(dim "not loaded")"
        fi
        ;;

    health)
        echo "=== Health Check ==="
        result=$(acurl GET /api/health 2>/dev/null) || { echo "$(red "Error: server unreachable")"; exit 1; }
        echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
status = d.get('status', 'unknown')
checks = d.get('checks', {})
print(f'  Overall: {status}')
print(f'  Uptime:  {checks.get(\"uptime\", \"?\")}')
for k, v in checks.items():
    if k == 'uptime':
        continue
    if isinstance(v, dict):
        s = v.get('status', '?')
        detail = ', '.join(f'{kk}={vv}' for kk, vv in v.items() if kk != 'status')
        print(f'  {k:10s} [{s}] {detail}')
    else:
        print(f'  {k:10s} {v}')
print(f'  Response: {d.get(\"response_ms\", \"?\")}ms')
" 2>/dev/null || echo "$result"
        ;;

    diagnostics|diag)
        echo "=== Diagnostics ==="
        result=$(acurl GET /api/diagnostics 2>/dev/null) || { echo "$(red "Error: server unreachable")"; exit 1; }
        echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
status = d.get('status', 'unknown')
colors = {'ok': '\033[32m', 'warning': '\033[33m', 'error': '\033[31m'}
reset = '\033[0m'
print(f'  Status: {colors.get(status.replace(\"healthy\",\"ok\").replace(\"degraded\",\"warning\").replace(\"unhealthy\",\"error\"), \"\")}{status}{reset}')
print(f'  Time:   {d.get(\"timestamp\", \"?\")}')
print(f'  Took:   {d.get(\"response_ms\", \"?\")}ms')
print()
for c in d.get('components', []):
    s = c.get('status', '?')
    color = colors.get(s, '')
    icon = '●' if s == 'ok' else '▲' if s == 'warning' else '✗'
    print(f'  {color}{icon}{reset} {c[\"name\"]:12s} {c.get(\"detail\", \"\")}')
" 2>/dev/null || echo "$result"
        ;;

    start)
        echo "Starting tracker-server via launchd..."
        launchctl load "$HOME/Library/LaunchAgents/$LAUNCHD_LABEL.plist" 2>/dev/null || true
        echo "$(green "Started.")"
        ;;

    stop)
        echo "Stopping tracker-server via launchd..."
        launchctl unload "$HOME/Library/LaunchAgents/$LAUNCHD_LABEL.plist" 2>/dev/null || true
        echo "$(green "Stopped.")"
        ;;

    restart)
        echo "Requesting graceful restart..."
        result=$(acurl POST /api/admin/restart 2>/dev/null) || { echo "$(red "Error: server unreachable")"; exit 1; }
        echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('message', str(d)))" 2>/dev/null || echo "$result"
        echo "Waiting for server to come back..."
        for i in $(seq 1 30); do
            sleep 1
            if curl -s -m 2 "$TRACKER_URL/health" >/dev/null 2>&1; then
                echo "$(green "Server is back up after ${i}s")"
                exit 0
            fi
        done
        echo "$(yellow "Server did not come back within 30s — check launchd")"
        ;;

    logs)
        shift
        if [[ "${1:-}" == "-f" ]]; then
            tail -f "$LOG_FILE" 2>/dev/null || echo "$(red "Log file not found: $LOG_FILE")"
        else
            lines="${1:-50}"
            tail -n "$lines" "$LOG_FILE" 2>/dev/null || echo "$(red "Log file not found: $LOG_FILE")"
        fi
        ;;

    clear-logs)
        echo "Clearing server logs..."
        result=$(acurl POST /api/admin/clear-logs 2>/dev/null) || { echo "$(red "Error: server unreachable")"; exit 1; }
        echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if d.get('success'):
    before = d.get('before_bytes', 0)
    if before > 1024*1024:
        size = f'{before/1024/1024:.1f}MB'
    elif before > 1024:
        size = f'{before/1024:.1f}KB'
    else:
        size = f'{before}B'
    print(f'Cleared {size} of logs.')
else:
    print(f'Error: {d.get(\"error\", \"unknown\")}')
" 2>/dev/null || echo "$result"
        ;;

    version)
        result=$(curl -s -m 2 "$TRACKER_URL/health" 2>/dev/null) || { echo "tracker CLI (server unreachable)"; exit 0; }
        ver=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('version','unknown'))" 2>/dev/null || echo "unknown")
        echo "Agent Tracker v${ver}"
        ;;

    help|--help|-h)
        cat <<'EOF'
Agent Tracker CLI

Usage: tracker <command> [options]

Commands:
  status        Show service running status (PID, port, launchd)
  health        Call /api/health, formatted output
  diagnostics   Run full system diagnostics (all components)
  start         Start launchd service
  stop          Stop launchd service
  restart       Graceful restart via API (waits for comeback)
  logs [N]      Show last N log lines (default: 50)
  logs -f       Follow log output
  clear-logs    Clear server log file
  version       Show server version
  help          Show this help
EOF
        ;;

    *)
        echo "Unknown command: $1"
        echo "Run 'tracker help' for usage."
        exit 1
        ;;
esac
